ENV=production
DEBUG=false
PORT=5001

# Security
SECRET_KEY=change-me-to-a-long-random-secret
JWT_EXP_HOURS=24

# Database (PostgreSQL)
DATABASE_URL=postgresql+psycopg://simpai:simpai_password@127.0.0.1:5432/simpai
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Redis (cache + rate limit storage)
REDIS_URL=redis://127.0.0.1:6379/0
CACHE_TYPE=RedisCache
CACHE_DEFAULT_TIMEOUT=60
RATELIMIT_STORAGE_URI=redis://127.0.0.1:6379/1
RATELIMIT_DEFAULT=300 per minute
QUIZ_IDEMPOTENCY_TTL_SECONDS=120

# AI integration
GEMINI_API_KEY=replace-with-real-key
AI_TIMEOUT_SECONDS=8
AI_CIRCUIT_FAIL_MAX=5
AI_CIRCUIT_RESET_SECONDS=30

# Gunicorn
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=30
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
